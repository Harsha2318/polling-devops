aws_region          = "ap-south-1"
project_name        = "polling-devops"
cluster_name        = "polling-eks"
public_subnet_cidrs = ["10.10.1.0/24", "10.10.2.0/24"]
availability_zones  = ["ap-south-1a", "ap-south-1b"]
node_instance_type  = "t3.small"
desired_size        = 2
min_size            = 1
max_size            = 2
node_disk_size      = 20

# For the final multi-node demo you can move to:
# desired_size = 3
# max_size     = 3

